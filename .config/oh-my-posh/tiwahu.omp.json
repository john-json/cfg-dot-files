{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "right",
      "segments": [
        {
          "background": "transparent",
          "foreground": "#ff8888",
          "style": "plain",
          "template": "{{ if gt .Code 0 }} {{ .Code }} {{ end }}",
          "type": "status"
        },
        {
          "background": "transparent",
          "foreground": "#ffcc88",
          "style": "plain",
          "template": "\uf0e7",
          "type": "root"
        },
        {
          "background": "transparent",
          "foreground": "#cccccc",
          "style": "plain",
          "template": " {{ if .WSL }}\uebcc {{ end }}{{.Icon}}",
          "type": "os"
        },
        {
          "background": "transparent",
          "foreground": "#666666",
          "style": "plain",
          "template": " {{ if .SSHSession }}\ueba9 {{ end }}{{ .UserName }} ",
          "type": "session"
        },
        {
          "background": "transparent",
          "foreground": "#cccccc",
          "options": {
            "folder_icon": "\u2026",
            "style": "mixed"
          },
          "style": "plain",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "transparent",
          "foreground": "#f1f0e9",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "style": "plain",
          "template": " {{ .HEAD }} ",
          "type": "git"
        },
        {
          "background": "transparent",
          "foreground": "#d2b06c",
          "options": {
            "fetch_version": false
          },
          "style": "plain",
          "template": " \ue77f ",
          "type": "dotnet"
        },
        {
          "background": "transparent",
          "foreground": "#ffffff",
          "options": {
            "fetch_version": false
          },
          "style": "plain",
          "template": " \ue626 ",
          "type": "go"
        },
        {
          "background": "transparent",
          "foreground": "#4c3dd3",
          "options": {
            "fetch_version": false
          },
          "style": "plain",
          "template": " \ue235 ",
          "type": "python"
        },
        {
          "background": "transparent",
          "foreground": "#4494cd",
          "options": {
            "fetch_version": false
          },
          "style": "plain",
          "template": " \ue7a8 ",
          "type": "rust"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#cf432B",
          "style": "plain",
          "template": "{{ .Name }} ",
          "type": "shell",
          "options": {
            "mapped_shell_names": {
              "pwsh": "\u276f",
              "shell": "\u276f",
              "cmd": ">",
              "lua": ">",
              "nu": ":)",
              "fish": "~>",
              "zsh": "\u276f",
              "bash": "\u276f"
            }
          }
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}