auto-update = download

theme = dark:twenty6-dark, light:twenty6-light, 
font-family = "JetBrainsMono Nerd Font Mono"

macos-titlebar-style = hidden
macos-titlebar-proxy-icon = hidden
macos-window-shadow = true
macos-window-buttons = hidden
macos-hidden = always

window-padding-x = 20
window-padding-y = 20
window-save-state = always
custom-shader-animation = always
window-theme = auto

quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.30
quick-terminal-autohide = false

shell-integration = zsh

macos-window-shadow = true

keybind = cmd+n=new_window
keybind = global:cmd+shift+d=toggle_quick_terminal
keybind = shift+cmd+q=quit
keybind = cmd+w=close_window
keybind = cmd+r=clear_screen
keybind = cmd+shift+r=reload_config